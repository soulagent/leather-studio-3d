{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Leather Studio 3D",
  "version": "0.0.10",
  "identifier": "com.leatherstuff.studio-3d",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Leather Studio 3D",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/soulagent/leather-studio-3d/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFMTVERTQ2NUFDREQ1RDEKUldUUjFjMWFSdDRWSGdKM1VpZTFkVEduWkhjaVJnZnJ3WTh3U0dKL21qV2p2V01hVHQzdmh6S3oK"
    }
  }
}
